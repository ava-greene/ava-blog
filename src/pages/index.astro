---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const typeConfig = {
  entry: { icon: '📝', label: 'Entry', color: '#00d4ff' },
  link: { icon: '🔗', label: 'Link', color: '#a855f7' },
  note: { icon: '💭', label: 'Note', color: '#10b981' },
  quote: { icon: '💬', label: 'Quote', color: '#f59e0b' },
};
---

<BaseLayout title="Ava Greene - Blog">
  <div class="header">
    <h2>Recent Posts</h2>
    <div class="type-filters">
      <a href={`${import.meta.env.BASE_URL}`} class="filter-all active">All</a>
      <a href={`${import.meta.env.BASE_URL}entries`} class="filter-tag">📝 Entries</a>
      <a href={`${import.meta.env.BASE_URL}links`} class="filter-tag">🔗 Links</a>
      <a href={`${import.meta.env.BASE_URL}notes`} class="filter-tag">💭 Notes</a>
      <a href={`${import.meta.env.BASE_URL}quotes`} class="filter-tag">💬 Quotes</a>
    </div>
  </div>

  {posts.length === 0 && (
    <p style="color: var(--text-secondary); font-style: italic;">No posts yet. Coming soon...</p>
  )}

  <div class="posts-timeline">
    {posts.map((post) => {
      const type = post.data.type || 'entry';
      const config = typeConfig[type];
      return (
        <article class={`post-item type-${type}`}>
          <div class="post-meta">
            <span class="post-type" style={`border-color: ${config.color}; color: ${config.color};`}>
              {config.icon} {config.label}
            </span>
            <time class="post-date">
              {post.data.date.toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric'
              })}
            </time>
          </div>
          <a href={`${import.meta.env.BASE_URL}posts/${post.slug}`} class="post-content">
            <h3 class="post-title">{post.data.title}</h3>
            {post.data.description && (
              <p class="post-description">{post.data.description}</p>
            )}
            {post.data.url && (
              <div class="external-link">
                ↗ {new URL(post.data.url).hostname}
              </div>
            )}
            {post.data.author && (
              <div class="quote-author">— {post.data.author}</div>
            )}
          </a>
        </article>
      );
    })}
  </div>

  <style>
    .header {
      margin-bottom: 3rem;
    }

    .header h2 {
      font-size: 1.75rem;
      color: var(--text-primary);
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    .type-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .filter-all,
    .filter-tag {
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-size: 0.875rem;
      font-family: 'JetBrains Mono', monospace;
      text-decoration: none;
      transition: all 0.2s;
      border: 1px solid var(--border);
      color: var(--text-secondary);
    }

    .filter-all.active {
      background: rgba(0, 212, 255, 0.1);
      border-color: var(--accent);
      color: var(--accent);
    }

    .filter-tag:hover {
      border-color: var(--accent);
      background: rgba(0, 212, 255, 0.05);
    }

    .posts-timeline {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .post-item {
      padding: 2rem 0;
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 2rem;
      transition: all 0.2s;
    }

    .post-item:hover {
      background: rgba(0, 212, 255, 0.02);
      margin-left: -1rem;
      margin-right: -1rem;
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .post-item:last-child {
      border-bottom: none;
    }

    .post-meta {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .post-type {
      font-size: 0.75rem;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 500;
      padding: 0.375rem 0.75rem;
      border-radius: 6px;
      border: 1.5px solid;
      background: rgba(0, 0, 0, 0.2);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .post-date {
      font-size: 0.8125rem;
      color: var(--text-secondary);
      font-family: 'JetBrains Mono', monospace;
    }

    .post-content {
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .post-title {
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.3;
      transition: color 0.2s;
      margin-bottom: 0.25rem;
    }

    .post-item:hover .post-title {
      color: var(--accent);
    }

    .post-description {
      color: var(--text-secondary);
      line-height: 1.6;
      font-size: 0.9375rem;
    }

    .external-link {
      font-size: 0.8125rem;
      color: var(--accent);
      font-family: 'JetBrains Mono', monospace;
      margin-top: 0.25rem;
    }

    .quote-author {
      font-size: 0.9375rem;
      color: var(--text-secondary);
      font-style: italic;
      margin-top: 0.5rem;
    }

    @media (max-width: 768px) {
      .post-item {
        grid-template-columns: 1fr;
        gap: 1rem;
      }
    }
  </style>
</BaseLayout>
