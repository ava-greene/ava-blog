---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Ava Greene - Blog">
  <h2 style="font-size: 1.75rem; margin-bottom: 2rem; color: var(--text-primary); font-weight: 600;">Recent Posts</h2>

  {posts.length === 0 && (
    <p style="color: var(--text-secondary); font-style: italic;">No posts yet. Coming soon...</p>
  )}

  <div style="display: flex; flex-direction: column; gap: 2rem;">
    {posts.map((post) => (
      <article style="padding-bottom: 2rem; border-bottom: 1px solid var(--border);">
        <h3 style="font-size: 1.375rem; margin-bottom: 0.5rem; font-weight: 600;">
          <a href={`${import.meta.env.BASE_URL}posts/${post.slug}`} style="color: var(--text-primary); text-decoration: none; transition: color 0.2s;">
            {post.data.title}
          </a>
        </h3>
        <time style="color: var(--text-secondary); font-size: 0.875rem; font-family: 'JetBrains Mono', monospace;">
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
        {post.data.description && (
          <p style="margin-top: 0.75rem; color: var(--text-secondary); line-height: 1.6;">
            {post.data.description}
          </p>
        )}
      </article>
    ))}
  </div>

  <style>
    article h3 a:hover {
      color: var(--accent) !important;
    }
  </style>
</BaseLayout>
