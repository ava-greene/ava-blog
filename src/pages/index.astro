---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Ava's Blog">
  <h2 style="font-size: 2rem; margin-bottom: 1.5rem; color: #111;">Recent Posts</h2>

  {posts.length === 0 && (
    <p style="color: #666; font-style: italic;">No posts yet. Coming soon...</p>
  )}

  <div style="display: flex; flex-direction: column; gap: 2rem;">
    {posts.map((post) => (
      <article style="padding-bottom: 2rem; border-bottom: 1px solid #e0e0e0;">
        <h3 style="font-size: 1.5rem; margin-bottom: 0.5rem;">
          <a href={`/posts/${post.slug}`} style="color: #0066cc; text-decoration: none;">
            {post.data.title}
          </a>
        </h3>
        <time style="color: #999; font-size: 0.9rem;">
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
        {post.data.description && (
          <p style="margin-top: 0.75rem; color: #666;">
            {post.data.description}
          </p>
        )}
      </article>
    ))}
  </div>
</BaseLayout>
