---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(post => post.data.type === 'quote' || !post.data.type)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Quotes - Ava Greene">
  <div class="header">
    <h2>💬 Quotes</h2>
    <div class="type-filters">
      <a href={import.meta.env.BASE_URL} class="filter-all">All</a>
      <a href={`${import.meta.env.BASE_URL}entries`} class="filter-tag active">💬 Entries</a>
      <a href={`${import.meta.env.BASE_URL}links`} class="filter-tag">🔗 Links</a>
      <a href={`${import.meta.env.BASE_URL}notes`} class="filter-tag">💭 Notes</a>
      <a href={`${import.meta.env.BASE_URL}quotes`} class="filter-tag">💬 Quotes</a>
    </div>
  </div>

  {posts.length === 0 && (
    <p style="color: var(--text-secondary); font-style: italic;">No quotes yet.</p>
  )}

  <div class="posts-timeline">
    {posts.map((post) => (
      <article class="post-item">
        <div class="post-meta">
          <span class="post-type" style="border-color: #f59e0b; color: #f59e0b;">
            💬 Quote
          </span>
          <time class="post-date">
            {post.data.date.toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric'
            })}
          </time>
        </div>
        <a href={`${import.meta.env.BASE_URL}posts/${post.slug}`} class="post-content">
          <h3 class="post-title">{post.data.title}</h3>
          {post.data.description && (
            <p class="post-description">{post.data.description}</p>
          )}
        </a>
      </article>
    ))}
  </div>

  <style>
    .header {
      margin-bottom: 3rem;
    }

    .header h2 {
      font-size: 1.75rem;
      color: var(--text-primary);
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    .type-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .filter-all,
    .filter-tag {
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-size: 0.875rem;
      font-family: 'JetBrains Mono', monospace;
      text-decoration: none;
      transition: all 0.2s;
      border: 1px solid var(--border);
      color: var(--text-secondary);
    }

    .filter-tag.active {
      background: rgba(0, 212, 255, 0.1);
      border-color: var(--accent);
      color: var(--accent);
    }

    .filter-all:hover,
    .filter-tag:hover {
      border-color: var(--accent);
      background: rgba(0, 212, 255, 0.05);
    }

    .posts-timeline {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .post-item {
      padding: 2rem 0;
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 2rem;
      transition: all 0.2s;
    }

    .post-item:hover {
      background: rgba(0, 212, 255, 0.02);
      margin-left: -1rem;
      margin-right: -1rem;
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .post-item:last-child {
      border-bottom: none;
    }

    .post-meta {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .post-type {
      font-size: 0.75rem;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 500;
      padding: 0.375rem 0.75rem;
      border-radius: 6px;
      border: 1.5px solid;
      background: rgba(0, 0, 0, 0.2);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .post-date {
      font-size: 0.8125rem;
      color: var(--text-secondary);
      font-family: 'JetBrains Mono', monospace;
    }

    .post-content {
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .post-title {
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.3;
      transition: color 0.2s;
      margin-bottom: 0.25rem;
    }

    .post-item:hover .post-title {
      color: var(--accent);
    }

    .post-description {
      color: var(--text-secondary);
      line-height: 1.6;
      font-size: 0.9375rem;
    }

    @media (max-width: 768px) {
      .post-item {
        grid-template-columns: 1fr;
        gap: 1rem;
      }
    }
  </style>
</BaseLayout>
