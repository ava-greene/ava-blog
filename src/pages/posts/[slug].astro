---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    <header style="margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 2px solid #e0e0e0;">
      <h2 style="font-size: 2.5rem; margin-bottom: 0.75rem; color: #111; line-height: 1.2;">
        {post.data.title}
      </h2>
      <time style="color: #999; font-size: 0.95rem;">
        {post.data.date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        })}
      </time>
    </header>

    <div style="line-height: 1.8; color: #444;">
      <Content />
    </div>
  </article>

  <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e0e0e0;">
    <a href={import.meta.env.BASE_URL} style="color: #0066cc; text-decoration: none;">← Back to all posts</a>
  </div>

  <style>
    article :global(h2) {
      font-size: 1.75rem;
      margin-top: 2rem;
      margin-bottom: 1rem;
      color: #222;
    }

    article :global(h3) {
      font-size: 1.4rem;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      color: #333;
    }

    article :global(p) {
      margin-bottom: 1rem;
    }

    article :global(a) {
      color: #0066cc;
      text-decoration: underline;
    }

    article :global(code) {
      background: #f5f5f5;
      padding: 0.2rem 0.4rem;
      border-radius: 3px;
      font-family: 'Courier New', monospace;
      font-size: 0.9em;
    }

    article :global(pre) {
      background: #2d2d2d;
      color: #f8f8f2;
      padding: 1rem;
      border-radius: 6px;
      overflow-x: auto;
      margin: 1.5rem 0;
    }

    article :global(pre code) {
      background: none;
      padding: 0;
    }

    article :global(ul), article :global(ol) {
      margin-left: 1.5rem;
      margin-bottom: 1rem;
    }

    article :global(li) {
      margin-bottom: 0.5rem;
    }

    article :global(blockquote) {
      border-left: 4px solid #0066cc;
      padding-left: 1rem;
      margin: 1.5rem 0;
      color: #666;
      font-style: italic;
    }
  </style>
</BaseLayout>
